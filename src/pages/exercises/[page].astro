---
import '@styles/post-container.css';

import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import Hero from '@components/Hero.astro';
import Pagination from '@components/Pagination.astro';

import { Formatter } from '@utils/formatter';

export const getStaticPaths = (async ({ paginate }) => {
  const blogPost = await getCollection('blog');
  const exercisePost = blogPost.filter(
    (post) => post.data.type === 'Ejercicio',
  );
  return paginate(exercisePost, { pageSize: 6 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout>
  <Hero
    title="Listado de Ejercicios"
    subtitle=" Completa uno de estos ejercicios, cumple las reglas, mejora, pero no nos hacemos respondables de la funa."
    tagline="¿Estas listo para un reto?"
  />
  <div class="section-container">
    <div class="grid-container">
      {
        page.data.map((exercisePost) => (
          <PostCard
            date={Formatter.formatDate(exercisePost.data.date)}
            title={exercisePost.data.title}
            desc={exercisePost.data.desc}
            slug={exercisePost.id}
          />
        ))
      }
    </div>
  </div>
  <Pagination
    currentPage={page.currentPage}
    totalPages={page.lastPage}
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    baseUrl="/exercises"
  />
</BaseLayout>
