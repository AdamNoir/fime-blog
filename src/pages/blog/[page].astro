---
import '@styles/post-container.css';

import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import Hero from '@components/Hero.astro';
import Pagination from '@components/Pagination.astro';

import { Formatter } from '@utils/formatter';

export const getStaticPaths = (async ({ paginate }) => {
  const blogPost = await getCollection('blog');
  const theoryPost = blogPost.filter((post) => post.data.type === 'Teoria');
  return paginate(theoryPost, { pageSize: 6 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<BaseLayout>
  <Hero
    tagline="Todo lo que necesitas saber para ser un gran escritor"
    title="Teoria para escritores"
    subtitle="Este es un compilado de teorias, notas, y documentacion de todo lo necesario para comenzar a escribir ficcion"
  />
  <div class="section-container">
    <div class="grid-container">
      {
        page.data.map((theoryPost) => (
          <PostCard
            date={Formatter.formatDate(theoryPost.data.date)}
            title={theoryPost.data.title}
            desc={theoryPost.data.desc}
            slug={theoryPost.id}
          />
        ))
      }
    </div>
  </div>
  <Pagination
    currentPage={page.currentPage}
    totalPages={page.lastPage}
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    baseUrl="/blog"
  />
</BaseLayout>
